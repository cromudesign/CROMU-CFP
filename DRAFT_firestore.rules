rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default-deny everything
    match /{document=**} {
      allow read, write: if false;
    }

    // Reuseable global helpers
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // Validation Blueprint for Transaction
    function isValidTransaction(data) {
      return data.keys().hasAll(['titulo', 'valor', 'tipo', 'data', 'status', 'userId', 'createdAt', 'updatedAt']) &&
             data.keys().size() == 8 &&
             data.titulo is string && data.titulo.size() <= 200 &&
             data.valor is number && data.valor >= 0 &&
             data.tipo in ['entrada', 'saida'] &&
             data.data is string && data.data.size() <= 20 &&
             data.status in ['pago', 'pendente'] &&
             data.userId == request.auth.uid &&
             data.createdAt is timestamp &&
             data.updatedAt is timestamp;
    }

    match /transactions/{transactionId} {
      allow get: if isOwner(existing().userId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn() && 
                      isValidId(transactionId) && 
                      isValidTransaction(incoming()) &&
                      incoming().createdAt == request.time &&
                      incoming().updatedAt == request.time;
      
      allow update: if isOwner(existing().userId) && 
                      isValidTransaction(incoming()) &&
                      incoming().createdAt == existing().createdAt && // Immutable
                      incoming().updatedAt == request.time &&
                      (
                        // Action: Toggle Status
                        incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']) ||
                        // Action: Full Edit
                        incoming().diff(existing()).affectedKeys().hasOnly(['titulo', 'valor', 'tipo', 'data', 'status', 'updatedAt'])
                      );
      
      allow delete: if isOwner(existing().userId);
    }
  }
}
